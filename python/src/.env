# Example .env file for the project.
# Copy to .env and fill in your values.

# URL or host of the DATASUS FTP
FTP_DATASUS=ftp://ftp.datasus.gov.br

# Temporary folder path for downloads
TEMP_DOWNLOAD_PATH=../tmp

# Start period (inclusive): year and month
START_YEAR=2025
START_MONTH=11

# End period (inclusive): year and month
END_YEAR=2026
END_MONTH=1

# Brazilian state codes (UF), comma-separated
STATES=SP,RJ,MG
