# Example .env file for the project.
# Copy to .env and fill in your values.

# URL or host of the DATASUS FTP
FTP_DATASUS=ftp://ftp.datasus.gov.br

# Temporary folder path for downloads
TEMP_DOWNLOAD_PATH=../tmp

# Temporary folder path for donwloaded files
TEMP_DBC_PATH=../tmp/dbc
TEMP_DBF_PATH=../tmp/dbf

# Temporary folder path for converted CSV files
TEMP_CSV_PATH=../tmp/csv

# Temporary folder path for ZIP files
TEMP_ZIP_FOLDER=../tmp/zip

# Temporary folder for extracted ZIP contents
TEMP_ZIP_EXTRACT_FOLDER=../tmp/extract

# Folder for IBGE municipalities CSV files (e.g. MUNICIPIOS.CSV)
CSV_IBGE_MUNICIPIOS_FOLDER=../tmp/csv_ibge_municipios

# Folder for IBGE UF (state) CSV files
CSV_IBGE_UF_FOLDER=../tmp/csv_ibge_uf

# Folder for nacionalidade CSV (NACION3D.CSV), uploaded to S3 raw/nacional/
CSV_NACIONAL_FOLDER=/tmp/csv_nacional

# Folder for IBGE SIGTAP CSV files
CSV_IBGE_SIGTAP_FOLDER=../tmp/csv_sigtap

# Folder for CID10 CSV files
CSV_IBGE_CID10_FOLDER=../tmp/csv_cid10

# If true/1/yes, fetch IBGE files (TAB_POP.zip, br_municip.cnv) and upload CSVs to S3 (raw/ibge/)
PROCESS_IBGE=false

# Start period (inclusive): year and month
START_YEAR=2023
START_MONTH=1

# End period (inclusive): year and month
END_YEAR=2023
END_MONTH=10

# Brazilian state codes (UF), comma-separated
STATES=SP,RJ,MG

# AWS S3 bucket name for the data lake
AWS_S3_BUCKET=datalake-bucket

# Local folder for CSV output; same structure as S3 but without raw/ (e.g. /data/sih, /data/sigtap)
DATA_PATH=../data
